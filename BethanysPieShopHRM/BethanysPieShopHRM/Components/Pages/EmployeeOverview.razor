@page "/employeeoverview"

<h1>Employee Overview</h1>

<table class="table table-light">
    <thead class="table-primary">
        <tr>
            <th></th>
            <th>Employee ID</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var employee in Employees)
        {
            <tr>
                <td><img src="@($"https://gillcleeren.blob.core.windows.net/person/{employee.EmployeeId}-small.jpg")" class="rounded-circle" alt="Employee Photo" /></td>
                <td>@employee.EmployeeId</td>
                <td>@employee.FirstName</td>
                <td>@employee.LastName</td>
                <td></td>
            </tr>
        }
    </tbody>
</table>